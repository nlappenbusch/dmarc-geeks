# Database
POSTGRES_USER=dmarc
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dmarc

# App
APP_PORT=8000

# Random 64+ char string. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-long-random-string

# Fernet key for encrypting IMAP passwords. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-me-with-fernet-key

# First-run superadmin (only used if no users exist yet)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=changeme
DEFAULT_TENANT_NAME=Default

# Polling
IMAP_POLL_INTERVAL_MINUTES=15

# DNS reverse-lookup for source IPs (set false to skip)
RESOLVE_PTR=true

# Public base URL — used for password-reset / signup email links
BASE_URL=http://localhost:8000

# Behind HTTPS reverse proxy? Set both to true for production.
COOKIE_SECURE=false
TRUSTED_PROXIES=false

# Allow self-service tenant signup
ALLOW_SIGNUP=false

# SMTP for outbound mail (forgot-password, signup, weekly digest, spike alerts).
# Leave host empty to disable mail features.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=dmarc-aggregator@localhost
